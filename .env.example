# AWS
AWS_REGION=ap-south-1
AWS_PROFILE=
S3_DATA_LAKE_BUCKET=sensor-data-lake-dev

# Kafka / MSK
KAFKA_BOOTSTRAP_SERVERS=boot-xxxx.c1.kafka-serverless.ap-south-1.amazonaws.com:9098
KAFKA_TOPIC=sensor.telemetry.raw
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=AWS_MSK_IAM

# Databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=
DATABRICKS_CLUSTER_ID=
DATABRICKS_SQL_WAREHOUSE_ID=
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA_BRONZE=bronze
DATABRICKS_SCHEMA_SILVER=silver
DATABRICKS_SCHEMA_GOLD=gold

# Local paths
SIMULATOR_OUTPUT_DIR=simulator/output
SHARED_DATA_DIR=shared/data
